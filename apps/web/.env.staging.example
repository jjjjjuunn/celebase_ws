# =============================================================================
# apps/web — STAGING environment variables
#
# Copy to .env.staging on the staging host (EC2 /app/.env.staging — gitignored).
# Fill values from: terraform outputs + AWS Secrets Manager + staging domain.
# Wired into docker-compose web service via env_file.
#
# preflight: scripts/preflight-env.sh apps/web — required keys must be non-empty.
# =============================================================================

# ----------------------------------------------------------------------------
# Required (preflight 검증 대상 — .env.staging.required 와 동기 유지)
# ----------------------------------------------------------------------------

# --- Internal session JWT (HS256) ---
# Must match INTERNAL_JWT_SECRET in user-service .env.staging
# preflight check: SHA256 equality with user-service runtime env
INTERNAL_JWT_SECRET=<from-secrets-manager, same as user-service>
INTERNAL_JWT_ISSUER=celebbase-user-service

# --- Cognito Hosted UI (fill from: cd infra/cognito && terraform output -json) ---
COGNITO_HOSTED_UI_DOMAIN=<terraform output -raw hosted_ui_domain>
COGNITO_CLIENT_ID=<terraform output -raw bff_client_id>
COGNITO_CLIENT_SECRET=<from-secrets-manager>
COGNITO_TOKEN_ENDPOINT=<terraform output -raw token_endpoint>
# Must match callback_urls registered in infra/cognito/variables.tf
# <STAGING_DOMAIN> = actual staging hostname (Route53 A record target)
COGNITO_REDIRECT_URI=https://<STAGING_DOMAIN>/api/auth/callback

# --- BE service URLs (server-side only — docker network internal) ---
USER_SERVICE_URL=http://user-service:3001
CONTENT_SERVICE_URL=http://content-service:3002
COMMERCE_SERVICE_URL=http://commerce-service:3004
MEAL_PLAN_URL=http://meal-plan-engine:3003
ANALYTICS_SERVICE_URL=http://analytics-service:3005

# ----------------------------------------------------------------------------
# Optional (preflight 검증 제외)
# ----------------------------------------------------------------------------

# Key rotation overlap — empty until first rotation
INTERNAL_JWT_SECRET_NEXT=

# WebSocket — NEXT_PUBLIC_* is baked into the build artifact (build-arg)
# Set via Docker build-arg in CI, not via this file. Listed here for reference.
NEXT_PUBLIC_WS_URL=wss://<STAGING_DOMAIN>
NEXT_PUBLIC_WS_HOST=<STAGING_DOMAIN>

# Mock claims feed flag (default: false). Leave empty for production behavior.
NEXT_PUBLIC_USE_MOCK_CLAIMS=
