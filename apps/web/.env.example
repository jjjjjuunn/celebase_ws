# =============================================================================
# CelebBase Wellness — apps/web environment variables
#
# Copy to .env.local and fill in real values for local dev.
# Sprint A scope: BFF routes proxy to BE services on the values below.
# =============================================================================

# ---------------------------------------------------------------------------
# Cognito (RS256 JWT verification via JWKS) — D15
# ---------------------------------------------------------------------------
# JWKS endpoint of the Cognito user pool. Public; no secret.
COGNITO_JWKS_URL=https://cognito-idp.<region>.amazonaws.com/<user-pool-id>/.well-known/jwks.json
# Issuer claim asserted on every cb_access verify. Must equal the user pool issuer.
COGNITO_ISSUER=https://cognito-idp.<region>.amazonaws.com/<user-pool-id>
# App client ID. Validated against the access_token aud claim.
COGNITO_AUDIENCE=<cognito-app-client-id>

# ---------------------------------------------------------------------------
# BE service URLs — server-side only (never bundled into client)
# Used by apps/web/src/app/api/_lib/bff-fetch.ts. Hardcoded localhost ports
# under apps/web/src outside /api/** are blocked by fe_bff_compliance gate.
# ---------------------------------------------------------------------------
USER_SERVICE_URL=http://localhost:3001
CONTENT_SERVICE_URL=http://localhost:3002
MEAL_PLAN_URL=http://localhost:3003

# ---------------------------------------------------------------------------
# WebSocket origin — public (D6). The BFF issues short-lived tickets via
# POST /api/ws-ticket; the client assembles the URL using this base.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_WS_URL=ws://localhost:3003
