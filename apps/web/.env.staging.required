# Required environment keys for apps/web staging deployment.
# Consumed by scripts/preflight-env.sh — one key per line, comments allowed.
# Optional vars (INTERNAL_JWT_SECRET_NEXT, NEXT_PUBLIC_*) live only in .env.staging.example.

INTERNAL_JWT_SECRET
INTERNAL_JWT_ISSUER
COGNITO_HOSTED_UI_DOMAIN
COGNITO_CLIENT_ID
COGNITO_CLIENT_SECRET
COGNITO_TOKEN_ENDPOINT
COGNITO_REDIRECT_URI
USER_SERVICE_URL
CONTENT_SERVICE_URL
COMMERCE_SERVICE_URL
MEAL_PLAN_URL
ANALYTICS_SERVICE_URL
