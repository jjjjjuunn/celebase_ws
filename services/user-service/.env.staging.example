# =============================================================================
# services/user-service — STAGING environment variables (CHORE-006)
#
# Copy to .env.staging (gitignored) and fill in real values from:
#   cd infra/cognito && terraform output -json
#
# Secret values (COGNITO_CLIENT_SECRET, INTERNAL_JWT_SECRET) are stored in
# AWS Secrets Manager at celebbase/staging/user-service.
# CHORE-007 will wire the runtime secrets loader; until then operators fill
# these manually from Secrets Manager.
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://celebbase:<password>@<staging-db-host>:5432/celebbase_staging
REDIS_URL=redis://<staging-redis-host>:6379

# --- Auth provider (staging must use cognito) ---
AUTH_PROVIDER=cognito

# --- Internal JWT (HS256 — issued by user-service, verified by all BE services) ---
# Generate: openssl rand -hex 32
# Must be ≥ 32 bytes and NOT 'dev-internal-secret-32-chars-pad'
INTERNAL_JWT_SECRET=<from-secrets-manager>
INTERNAL_JWT_ISSUER=celebbase-user-service

# --- AWS Cognito (fill from: cd infra/cognito && terraform output -json) ---
AWS_REGION=us-west-2
COGNITO_USER_POOL_ID=<terraform output -raw user_pool_id>
COGNITO_CLIENT_ID=<terraform output -raw bff_client_id>
COGNITO_JWKS_URI=<terraform output -raw jwks_uri>
# IMPORTANT: no trailing slash — Cognito issuer is exact-matched by jose
COGNITO_ISSUER=<terraform output -raw issuer>

# --- PHI Encryption ---
PHI_ENCRYPTION_KEY=<64-char hex, 32 bytes — rotate from dev key>

# --- SQS ---
SQS_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/<account-id>/meal-plan-generation

# --- App ---
NODE_ENV=production
LOG_LEVEL=info
PORT=3001
HOST=0.0.0.0
