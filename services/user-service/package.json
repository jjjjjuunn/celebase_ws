{
  "name": "@celebbase/user-service",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src/",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "dependencies": {
    "@celebbase/service-core": "workspace:*",
    "@celebbase/shared-types": "workspace:*",
    "jose": "^6.2.2",
    "redis": "^4.7.0",
    "uuidv7": "^1.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@fastify/rate-limit": "^10.0.0",
    "@types/jest": "^29.5.14",
    "@types/pg": "^8.11.10",
    "fastify": "^5.1.0",
    "jest": "^29.7.0",
    "pg": "^8.13.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.0"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  }
}
