    "db:seed": "turbo run seed --filter=db"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.1"
  }
}
