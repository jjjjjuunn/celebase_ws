{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**",
        "tsconfig*.json",
        "package.json",
        "**/*.py",
        "requirements.txt",
        "pyproject.toml"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "dev": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**",
        "tests/**",
        "scripts/**",
        "**/*.py",
        "eslint.config*",
        ".eslintrc*",
        "tsconfig*.json",
        "ruff.toml",
        "pyproject.toml",
        "package.json"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**",
        "tsconfig*.json",
        "package.json"
      ]
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**",
        "tests/**",
        "test/**",
        "**/*.py",
        "jest.config*",
        "package.json",
        "requirements.txt"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "migrate": {
      "cache": false
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "build-storybook": {
      "inputs": [
        "src/**",
        "stories/**",
        "*.config.*",
        "package.json"
      ],
      "outputs": [
        "storybook-static/**"
      ]
    }
  }
}
