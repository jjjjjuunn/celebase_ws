{
  "name": "celebbase-wellness",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:migrate": "turbo run migrate --filter=db",
    "db:seed": "turbo run seed --filter=db",
    "smoke:cognito": "tsx scripts/smoke/cognito-hosted-ui.ts",
    "seed:cognito": "bash scripts/seed/cognito-staging-users.sh"
  },
  "devDependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.0.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.0.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "zod": "^3.24.1"
  }
}
