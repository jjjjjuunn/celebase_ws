# apps/mobile — Expo / React Native 환경 변수 템플릿
# 사용법: 이 파일을 .env 로 복사 후 실제 값 채우기. .env 는 .gitignore.
#
# Expo 의 환경 변수 노출 규칙: EXPO_PUBLIC_ 접두사가 붙은 변수만 client bundle 에
# 포함됨. 그 외 변수는 build-time 만 사용 가능.
# 참고: https://docs.expo.dev/guides/environment-variables/

# ─────────────────────────────────────────────────────────
# BFF (Next.js apps/web) 엔드포인트 — mobile 의 active gateway
# ─────────────────────────────────────────────────────────
# 로컬 개발: http://localhost:3000 또는 LAN IP (`http://192.168.x.x:3000`)
# 시뮬레이터/Expo Go 에서 접근 가능해야 함 — localhost 가 안 되면 LAN IP 사용.
# Staging: https://<STAGING_DOMAIN> (e.g. staging.celebbase.com — operator
#   provisioned per CHORE-MOBILE-STAGING-BFF-001 P2/P3, Caddy + LE TLS)
# Production: TBD (separate prod chore)
EXPO_PUBLIC_BFF_BASE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────
# user-service 직접 호출 (예외 — /auth/refresh 만)
# ─────────────────────────────────────────────────────────
# spec.md §11 Mobile auth ingress 결정: /auth/refresh 는 BFF 가 cookie-shaped
# 라 mobile 이 user-service 를 직접 호출. 그 외 모든 path 는 BFF 경유.
# 로컬 개발: http://localhost:3001
# Staging: same hostname as BFF (https://<STAGING_DOMAIN>). Caddy routes
#   the /auth/refresh path to user-service:3001 — user-service stays off the
#   public internet, the path matcher in docker/caddy/Caddyfile does the split.
#   So set this to the same value as EXPO_PUBLIC_BFF_BASE_URL on staging.
# Production: TBD
EXPO_PUBLIC_USER_SERVICE_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────
# Cognito (AWS) — Amplify SRP 인증
# ─────────────────────────────────────────────────────────
# IMPL-MOBILE-AUTH-001 (PR #36) 에서 신설된 mobile 전용 public client.
# Cognito User Pool 의 mobile App Client ID — public bucket OK
# (Amplify SRP 가 password 직접 송신 안하므로 client id 노출 안전).
EXPO_PUBLIC_COGNITO_USER_POOL_ID=us-west-2_XXXXXXXXX
EXPO_PUBLIC_COGNITO_MOBILE_CLIENT_ID=

# AWS region — Cognito User Pool 리전과 동일
EXPO_PUBLIC_AWS_REGION=us-west-2

# ─────────────────────────────────────────────────────────
# RevenueCat (M5 IAP — 결제)
# ─────────────────────────────────────────────────────────
# RevenueCat dashboard 의 Public SDK API Key (Android/iOS 별 분리 가능).
# 사용자 결제 처리 + 구독 상태 조회용. 동료 M5 진입 시 채움.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
