{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CelebBase Tasks Schema",
  "description": "tasks.yaml 구조 강제 — 태스크 상태 관리 및 DoD 추���",
  "type": "object",
  "required": ["tasks"],
  "properties": {
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "owner", "dependsOn", "status", "definitionOfDone"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z]+-\\d{3}(-[a-z])?$",
            "description": "태스크 ID (예: BOOT-001, IMPL-004-a). sub-task 분할 시 -a/-b/-c 소문자 suffix."
          },
          "title": {
            "type": "string",
            "minLength": 5,
            "maxLength": 200
          },
          "owner": {
            "type": "string",
            "pattern": "^(agent-[a-z0-9-]+|human-[a-z0-9-]+)( \\+ (agent-[a-z0-9-]+|human-[a-z0-9-]+))*$",
            "description": "소유자. 단일 또는 복합 (예: 'agent-claude-opus-4-6 + agent-codex-o3'). agent-/human- prefix 강제 — 에이전트가 사람으로 위장해 크로스체크 우회 방지."
          },
          "dependsOn": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Z]+-\\d{3}(-[a-z])?$"
            }
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in-progress", "done", "blocked"]
          },
          "definitionOfDone": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 5
            }
          }
        },
        "additionalProperties": false
      }
    }
  }
}
