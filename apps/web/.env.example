# =============================================================================
# CelebBase Wellness — apps/web environment variables
#
# Copy to .env.local and fill in real values for local dev.
# Sprint B scope: BFF routes proxy to BE services; Cognito Hosted UI redirect
# flow; internal HS256 session tokens issued by user-service.
# =============================================================================

# ---------------------------------------------------------------------------
# Internal session JWT (HS256) — D18
# BFF verifies tokens issued by user-service after Cognito id_token exchange.
# Cognito id_tokens never reach the BFF directly.
#
# INTERNAL_JWT_SECRET       — required in production (readEnv throws if unset).
#                              Dev/test falls back to DEFAULT_DEV_SECRET so
#                              first-run local / jest / typecheck don't crash.
# INTERNAL_JWT_SECRET_NEXT  — optional; enables zero-downtime key rotation.
#                              Verifier tries NEXT first, falls back to CURRENT
#                              on signature-only failure. Overlap ≥ session TTL
#                              (1h). Remove OLD to complete cutover.
#                              See docs/runbooks/internal-jwt-rotation.md.
# INTERNAL_JWT_ISSUER       — optional; defaults to 'celebbase-user-service'.
# ---------------------------------------------------------------------------
INTERNAL_JWT_SECRET=change-me-in-prod-use-openssl-rand-base64-32
INTERNAL_JWT_SECRET_NEXT=
INTERNAL_JWT_ISSUER=celebbase-user-service

# ---------------------------------------------------------------------------
# Cognito Hosted UI — OAuth 2.0 authorization code flow (D19, D20)
# BFF redirects browser to Hosted UI for login/signup, then exchanges the
# returned `code` at COGNITO_TOKEN_ENDPOINT using client_secret_basic.
# ---------------------------------------------------------------------------
COGNITO_HOSTED_UI_DOMAIN=<user-pool-domain>.auth.<region>.amazoncognito.com
COGNITO_CLIENT_ID=<cognito-app-client-id>
COGNITO_CLIENT_SECRET=<cognito-app-client-secret>
COGNITO_TOKEN_ENDPOINT=https://<user-pool-domain>.auth.<region>.amazoncognito.com/oauth2/token
COGNITO_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ---------------------------------------------------------------------------
# BE service URLs — server-side only (never bundled into client)
# Used by apps/web/src/app/api/_lib/bff-fetch.ts. Hardcoded localhost ports
# under apps/web/src outside /api/** are blocked by fe_bff_compliance gate.
# ---------------------------------------------------------------------------
USER_SERVICE_URL=http://localhost:3001
CONTENT_SERVICE_URL=http://localhost:3002
MEAL_PLAN_URL=http://localhost:3003
COMMERCE_SERVICE_URL=http://localhost:3004
ANALYTICS_SERVICE_URL=http://localhost:3005

# ---------------------------------------------------------------------------
# WebSocket — public (D6, D28)
# NEXT_PUBLIC_WS_URL   — full base URL used by the browser client to assemble
#                        `${NEXT_PUBLIC_WS_URL}/ws/meal-plans/:id/status?ticket=...`.
# NEXT_PUBLIC_WS_HOST  — host-only value interpolated into the baseline CSP
#                        `connect-src wss://${NEXT_PUBLIC_WS_HOST}` directive.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_WS_URL=ws://localhost:3003
NEXT_PUBLIC_WS_HOST=localhost:3003
