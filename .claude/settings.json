{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Claude 전용 어댑터. 공통 정책은 harness/policy.yaml 참조. 다른 모델 사용 시 이 파일만 교체.",
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@anthropic-ai/mcp-server-playwright"]
    },
    "codex": {
      "command": "codex",
      "args": ["mcp-server"]
    }
  },
  "permissions": {
    "allow": [
      "Bash(pnpm --filter web typecheck *)",
      "Bash(pnpm --filter web lint *)",
      "Bash(pnpm --filter shared-types build *)",
      "Bash(pnpm --filter @celebbase/ui-kit build *)",
      "Bash(pnpm --filter @celebbase/ui-kit typecheck *)",
      "Bash(pnpm --filter @celebbase/design-tokens build *)",
      "Bash(textutil -convert txt -stdout *)",
      "Bash(scripts/gate-check.sh fe_token_hardcode *)",
      "Bash(scripts/gate-check.sh fe_bff_compliance *)"
    ]
  }
}
